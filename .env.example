# Server
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Auth (rotate before any non-local deployment)
API_KEY=dev-local-key-change-me

# Database
DATABASE_URL=postgresql+asyncpg://neuronova:neuronova@localhost:5432/neuronova

# Storage
STORAGE_BACKEND=local
DATA_DIR=./data
MAX_UPLOAD_BYTES=104857600

# OpenAI (Layer 5+)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_MINI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
